{
	"arrowParens": "always",
	"bracketSpacing": true,
	"jsxSingleQuote": true,
	"printWidth": 100,
	"semi": true,
	"singleQuote": true,
  	"endOfLine": "auto",
	"useTabs": true,
	"plugins": ["prettier-plugin-svelte"],
	"pluginSearchDirs": ["."],
	"overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }]
}